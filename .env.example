# Copy to .env for local development.
LOCAL_ADMIN_TOKEN=change_me

# Cloudflare settings
# Cloudflare Worker API 地址，compute/verify 会优先读取这里
# CLOUDFLARE_API_URL=https://dcalab.juryory.com

# Cloudflare 审核管理员 token，仅 verify 和云端审核接口使用
# CLOUDFLARE_ADMIN_TOKEN=replace_me

# Optional tuning
# RANGE_WORKERS=1
# 正式区间搜索 worker 数，默认按机器核数自动分档
# ROBUST_WORKERS=1
# 正式稳健性搜索 worker 数，默认按机器核数自动分档
# TASK_WORKERS=1
# strategy_lab 本地后台任务 worker 数，默认按机器核数自动分档
# TOTAL_WORKERS=2
# 本机允许同时运行的计算 worker 总预算，避免把小机器打满

# Compute defaults
# COMPUTE_SUBMIT_INTERVAL_SECONDS=30
# compute_node 上传间隔，单位秒
# COMPUTE_BATCH=50
# compute_node 每轮搜索/上报的批量大小
# COMPUTE_PENALTY=0.08
# compute_node 默认惩罚权重
